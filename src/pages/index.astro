---
import Layout from "@/layouts/Layout.astro";

const { user } = Astro.locals;
---

<Layout title="10xCards">
  <div class="bg-cosmic flex min-h-[calc(100vh-53px)] items-center justify-center p-6">
    <div class="w-full max-w-md text-center">
      {
        user ? (
          <div class="rounded-2xl border border-white/10 bg-white/5 p-10 backdrop-blur-sm">
            <h1 class="mb-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
              Welcome back
            </h1>
            <p class="mb-8 text-sm text-blue-100/60">{user.email}</p>
            <a
              href="/generate"
              class="inline-block rounded-lg bg-purple-600 px-8 py-3 font-medium text-white transition-colors hover:bg-purple-500"
            >
              Generate Flashcards
            </a>
            <p class="mt-4">
              <a href="/deck" class="text-sm text-blue-100/50 underline hover:text-blue-100/80">
                View my deck →
              </a>
            </p>
          </div>
        ) : (
          <div class="rounded-2xl border border-white/10 bg-white/5 p-10 backdrop-blur-sm">
            <h1 class="mb-3 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-4xl font-bold text-transparent">
              10xCards
            </h1>
            <p class="mb-8 text-blue-100/60">
              Paste any text — AI generates flashcard candidates. You review, accept, and study.
            </p>
            <div class="flex justify-center gap-3">
              <a
                href="/auth/signin"
                class="rounded-lg bg-purple-600 px-6 py-2.5 font-medium text-white transition-colors hover:bg-purple-500"
              >
                Sign in
              </a>
              <a
                href="/auth/signup"
                class="rounded-lg border border-white/20 px-6 py-2.5 font-medium text-white transition-colors hover:bg-white/10"
              >
                Sign up
              </a>
            </div>
          </div>
        )
      }
    </div>
  </div>
</Layout>
