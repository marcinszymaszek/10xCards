---
import Layout from "@/layouts/Layout.astro";
import ReviewSession from "@/components/review/ReviewSession";
import { createClient } from "@/lib/supabase";
import { fetchDueCards, type ReviewCard } from "@/lib/reviews";

const supabase = createClient(Astro.request.headers, Astro.cookies);

let cards: ReviewCard[] = [];
if (supabase) {
  try {
    cards = await fetchDueCards(supabase);
  } catch {
    // SSR fetch failed — render an empty queue; the user can refresh to retry
  }
}
---

<Layout title="Review">
  <div class="bg-cosmic min-h-screen p-6">
    <div class="mx-auto max-w-2xl">
      <h1 class="mb-6 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
        Review
      </h1>
      <ReviewSession client:load initialCards={cards} />
    </div>
  </div>
</Layout>
