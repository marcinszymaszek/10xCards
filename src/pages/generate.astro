---
import Layout from "@/layouts/Layout.astro";
import GenerationView, { type DraftCardInput } from "@/components/generate/GenerationView";
import { createClient } from "@/lib/supabase";

const supabase = createClient(Astro.request.headers, Astro.cookies);

let initialDrafts: DraftCardInput[] = [];

if (supabase) {
  try {
    const { data: sessionRow } = await supabase
      .from("flashcard_drafts")
      .select("generation_session_id")
      .eq("state", "pending")
      .order("created_at", { ascending: false })
      .limit(1)
      .maybeSingle();

    if (sessionRow !== null) {
      const { data: drafts } = await supabase
        .from("flashcard_drafts")
        .select("id, front, back, generation_session_id")
        .eq("generation_session_id", sessionRow.generation_session_id)
        .eq("state", "pending")
        .order("created_at", { ascending: true });

      initialDrafts = drafts ?? [];
    }
  } catch {
    // SSR fetch failed — fall back to idle state
  }
}
---

<Layout title="Generate Flashcards">
  <div class="bg-cosmic min-h-[calc(100vh-53px)] p-6 text-white">
    <div class="mx-auto max-w-2xl">
      <GenerationView client:load initialDrafts={initialDrafts} />
    </div>
  </div>
</Layout>
