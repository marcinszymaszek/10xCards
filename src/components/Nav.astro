---
const { user } = Astro.locals;
const path = Astro.url.pathname;
---

<nav class="flex items-center justify-between border-b border-white/10 bg-black/85 px-6 py-3 backdrop-blur-sm">
  <a href="/" class="text-lg font-bold text-white">10xCards</a>

  {
    user && (
      <div class="flex items-center gap-6">
        <a
          href="/generate"
          class:list={`text-sm transition-colors ${path === "/generate" ? "text-white" : "text-blue-100/70 hover:text-white"}`}
        >
          Generate
        </a>
        <a
          href="/deck"
          class:list={`text-sm transition-colors ${path === "/deck" ? "text-white" : "text-blue-100/70 hover:text-white"}`}
        >
          Deck
        </a>
      </div>
    )
  }

  <div class="flex items-center gap-4">
    {
      user ? (
        <>
          <span class="text-xs text-blue-100/50">{user.email}</span>
          <form method="POST" action="/api/auth/signout">
            <button type="submit" class="text-sm text-blue-100/70 transition-colors hover:text-white">
              Sign out
            </button>
          </form>
        </>
      ) : (
        <>
          <a href="/auth/signin" class="text-sm text-blue-100/70 transition-colors hover:text-white">
            Sign in
          </a>
          <a
            href="/auth/signup"
            class="rounded-lg bg-purple-600 px-4 py-1.5 text-sm font-medium text-white transition-colors hover:bg-purple-500"
          >
            Sign up
          </a>
        </>
      )
    }
  </div>
</nav>
